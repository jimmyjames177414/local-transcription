<!-- Shared control styles. Brushes are referenced via DynamicResource so swapping the
     token dictionary (dark/light) restyles everything. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- One transcript turn (TranscriptRowViewModel). Shared by the live Meeting list,
         the Sessions detail preview, and review mode. -->
    <DataTemplate x:Key="TranscriptRowTemplate">
        <Border x:Name="RowBd" CornerRadius="5" Padding="6,2" Margin="0,0,0,3"
                Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <!-- Right-click "Delete line" — only in editable lists (Meeting/review), not the read-only Sessions preview. -->
                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="editable">
                            <Setter Property="ContextMenu">
                                <Setter.Value>
                                    <ContextMenu>
                                        <MenuItem Header="Delete line"
                                                  Command="{Binding PlacementTarget.Tag.Session.DeleteLineCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Time}" FontFamily="{DynamicResource Font.Mono}"
                           FontSize="9.5" Foreground="{DynamicResource Brush.Text.Timestamp}" Margin="0,1,8,0" />
                <TextBlock Grid.Column="1" TextWrapping="Wrap" FontSize="11.5" LineHeight="17">
                    <!-- Speaker name: clickable hyperlink for unidentified session speakers, plain run otherwise -->
                    <Hyperlink Command="{Binding DataContext.Session.RenameSpeakerCommand,
                                        RelativeSource={RelativeSource AncestorType=ListBox}}"
                               CommandParameter="{Binding}"
                               Foreground="{Binding SpeakerBrush}">
                        <Hyperlink.Style>
                            <Style TargetType="Hyperlink">
                                <!-- Default: inert plain text. The speaker name is a live rename link
                                     only in editable lists (Meeting/review) AND for a renamable
                                     (unidentified) speaker. The read-only Sessions preview has no
                                     Session on the DataContext, so the Command would bind to null;
                                     keep it disabled and non-interactive there (mirrors the ✕ delete
                                     button's Tag=="editable" gate). -->
                                <Setter Property="IsEnabled" Value="False" />
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter Property="TextDecorations" Value="{x:Null}" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="editable" />
                                            <Condition Binding="{Binding CanRename}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="IsEnabled" Value="True" />
                                        <Setter Property="Cursor" Value="Hand" />
                                    </MultiDataTrigger>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="editable" />
                                            <Condition Binding="{Binding CanRename}" Value="True" />
                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="TextDecorations" Value="Underline" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Hyperlink.Style>
                        <Run Text="{Binding SpeakerName, Mode=OneWay}" FontWeight="SemiBold" />
                    </Hyperlink><Run
                        Text="{Binding MicMark, Mode=OneWay}" FontSize="9" Foreground="{Binding SpeakerBrush}" /><Run
                        Text="{Binding UncertainMark, Mode=OneWay}" Foreground="{DynamicResource Brush.Uncertain.Text}" />
                    <Run Text="{Binding Text, Mode=OneWay}" Foreground="{DynamicResource Brush.Text.Body}" />
                    <Run Text="{Binding ConfidenceText, Mode=OneWay}" FontFamily="{DynamicResource Font.Mono}"
                         FontSize="9" Foreground="{DynamicResource Brush.Uncertain.Text}" />
                </TextBlock>
                <!-- Hover ✕ delete: shown only on row hover in editable (Meeting/review) lists. -->
                <Button Grid.Column="2" Content="✕" FontSize="10" Padding="5,0" Margin="6,0,0,0"
                        VerticalAlignment="Top" Cursor="Hand"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource Brush.Text.Faint}"
                        ToolTip="Delete this line"
                        Command="{Binding DataContext.Session.DeleteLineCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                        CommandParameter="{Binding}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="editable" />
                                        <Condition Binding="{Binding IsMouseOver, ElementName=RowBd}" Value="True" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding IsUncertain}" Value="True">
                <Setter TargetName="RowBd" Property="Background" Value="{DynamicResource Brush.Uncertain.Bg}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- Panel section label: "TRANSCRIPT", "ASSISTANT", "NOTES" -->
    <Style x:Key="PanelLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Muted}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Monospace meta text: timestamps, session ids, paths -->
    <Style x:Key="MonoTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Faint}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Body / hint text helpers -->
    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Body}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style x:Key="HintTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Hint}" />
        <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <!-- Primary (accent) button -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Brush.Accent.Gradient}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="16,7" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.9" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.8" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Record button (red gradient) -->
    <Style x:Key="RecordButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Rec.Gradient}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="26,10" />
    </Style>

    <!-- Subtle outline button -->
    <Style x:Key="SubtleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Body}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="7"
                            BorderBrush="{DynamicResource Brush.Stroke.Hi}" BorderThickness="1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Surface.Hi}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Solid neutral button (Pause) -->
    <Style x:Key="NeutralButtonStyle" TargetType="Button" BasedOn="{StaticResource SubtleButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Stroke.Hi}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Danger button (Stop / Forget) -->
    <Style x:Key="DangerButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource Brush.Danger.Bg}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Danger.Text}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="7"
                            BorderBrush="{DynamicResource Brush.Danger.Border}" BorderThickness="1"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Rec.Bg}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Solid destructive confirm button ("Forget voice") -->
    <Style x:Key="DangerSolidButtonStyle" TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Danger.Deep}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- Pill chip (radius 99) -->
    <Style x:Key="ChipBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="99" />
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Chrome}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Stroke.Hi}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="11,4" />
    </Style>

    <!-- Card -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Chrome}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Stroke}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="15,14" />
    </Style>

    <!-- Pulsing dot (recording / live indicators) -->
    <Style x:Key="PulseDotStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Fill" Value="{DynamicResource Brush.Rec}" />
        <Style.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                         From="1" To="0.35" Duration="0:0:0.7"
                                         AutoReverse="True" RepeatBehavior="Forever" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- Text input -->
    <Style x:Key="TextInputStyle" TargetType="TextBox">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Input}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="CaretBrush" Value="{DynamicResource Brush.Accent.Soft}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Surface.Hi}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="9,6" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Monospace path input -->
    <Style x:Key="PathInputStyle" TargetType="TextBox" BasedOn="{StaticResource TextInputStyle}">
        <Setter Property="FontFamily" Value="{DynamicResource Font.Mono}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Body}" />
    </Style>

    <!-- Toggle switch (restyled CheckBox): 34x18 track, 14px thumb -->
    <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
        <Setter Property="FontSize" Value="12.5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="Track" Width="34" Height="18" CornerRadius="9"
                                Background="{DynamicResource Brush.Surface.Hi}" VerticalAlignment="Center">
                            <Ellipse x:Name="Thumb" Width="14" Height="14" Fill="White"
                                     HorizontalAlignment="Left" Margin="2,0,0,0" />
                        </Border>
                        <ContentPresenter Margin="11,0,0,0" VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background" Value="{DynamicResource Brush.Accent}" />
                            <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox item -->
    <Style x:Key="ComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Body}" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="5"
                            Padding="{TemplateBinding Padding}" Margin="4,2">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Surface.Hi}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Accent.Text}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox: matches TextInputStyle rounding; arrow + dark popup -->
    <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background" Value="{DynamicResource Brush.Bg.Input}" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Body}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Surface.Hi}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Padding" Value="9,5" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource ComboBoxItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- ToggleButton is the hit-testable element that flips IsDropDownOpen (which PART_Popup binds to). -->
                        <ToggleButton x:Name="PART_ToggleButton"
                                      ClickMode="Press"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                            <ToggleButton.Template>
                                <!-- Transparent template: no default chrome, just render the ComboBox chrome below. -->
                                <ControlTemplate TargetType="ToggleButton">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </ToggleButton.Template>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid Margin="{TemplateBinding Padding}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="ContentSite" Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                      VerticalAlignment="Center"
                                                      IsHitTestVisible="False" />
                                    <TextBlock Grid.Column="1" Text="▾" FontSize="13"
                                               Foreground="{DynamicResource Brush.Text.Faint}"
                                               VerticalAlignment="Center" Margin="8,0,2,0"
                                               IsHitTestVisible="False" />
                                </Grid>
                            </Border>
                        </ToggleButton>
                        <!-- Editable entry: visible only when IsEditable=True; sits above the toggle so it's typeable. -->
                        <TextBox x:Name="PART_EditableTextBox"
                                 Visibility="Hidden"
                                 Margin="10,5,30,5"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{TemplateBinding Foreground}"
                                 CaretBrush="{TemplateBinding Foreground}"
                                 IsReadOnly="{TemplateBinding IsReadOnly}" />
                        <Popup x:Name="PART_Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Fade"
                               MinWidth="{TemplateBinding ActualWidth}">
                            <Border Background="{DynamicResource Brush.Bg.Chrome}"
                                    BorderBrush="{DynamicResource Brush.Stroke.Hi}"
                                    BorderThickness="1" CornerRadius="8" Margin="0,3,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="14" ShadowDepth="4" Opacity="0.45" />
                                </Border.Effect>
                                <ScrollViewer Padding="0,4" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Surface.Hi}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Nav pills (segmented tabs as ListBox per spec 4i) -->
    <Style x:Key="NavPillListBoxStyle" TargetType="ListBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ListBoxItem">
                    <Setter Property="FontFamily" Value="{DynamicResource Font.Ui}" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="Foreground" Value="{DynamicResource Brush.Nav.Inactive}" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Margin" Value="0,0,2,0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" CornerRadius="6" Padding="13,5" Background="Transparent">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Surface.Hi}" />
                                        <Setter Property="Foreground" Value="White" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsMouseOver" Value="True" />
                                            <Condition Property="IsSelected" Value="False" />
                                        </MultiTrigger.Conditions>
                                        <Setter Property="Foreground" Value="{DynamicResource Brush.Text.Primary}" />
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Title-bar caption buttons -->
    <Style x:Key="CaptionButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Brush.Caption.Fg}" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Width" Value="42" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Surface.Hi}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="CloseCaptionButtonStyle" TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFC42B1C" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
