<Window x:Class="LocalTranscriber.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalTranscriber" Height="560" Width="820" MinHeight="420" MinWidth="640">
    <TabControl>
        <TabItem Header="Session">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="LocalTranscriber" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Session.StatusText, StringFormat='Status: {0}'}" FontSize="14" Margin="24,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Session.SessionId, StringFormat='Session: {0}'}" FontSize="12" Foreground="Gray" Margin="24,0,0,0" VerticalAlignment="Center" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Output folder:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding Session.OutputFolder, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Content="Browse..." Margin="8,0,0,0" Padding="12,2" Click="BrowseOutputFolder_Click" />
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Start" Width="90" Margin="0,0,8,0" Command="{Binding Session.StartCommand}" />
                    <Button Content="Stop" Width="90" Margin="0,0,8,0" Command="{Binding Session.StopCommand}" />
                    <Button Content="Pause" Width="90" Margin="0,0,8,0" Command="{Binding Session.PauseCommand}" />
                    <Button Content="Resume" Width="90" Margin="0,0,8,0" Command="{Binding Session.ResumeCommand}" />
                    <Button Content="Clear preview" Width="110" Command="{Binding Session.ClearPreviewCommand}" />
                </StackPanel>

                <TextBox Grid.Row="3"
                         Text="{Binding Session.PreviewText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         TextChanged="Preview_TextChanged" />

                <TextBlock Grid.Row="4" Text="{Binding Session.ErrorText}" Foreground="DarkRed" Margin="0,8,0,0" TextWrapping="Wrap" />
            </Grid>
        </TabItem>

        <TabItem Header="Agent">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <CheckBox Content="Enable agent" IsChecked="{Binding AgentPanel.AgentEnabled}" VerticalAlignment="Center" />
                    <TextBlock Text="Mode:" Margin="18,0,6,0" VerticalAlignment="Center" />
                    <ComboBox Width="150" ItemsSource="{Binding AgentPanel.Modes}" SelectedItem="{Binding AgentPanel.SelectedMode}" />
                    <TextBlock Text="Provider:" Margin="18,0,6,0" VerticalAlignment="Center" />
                    <ComboBox Width="120" ItemsSource="{Binding AgentPanel.Providers}" SelectedItem="{Binding AgentPanel.SelectedProvider}" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Context folder:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Grid.Column="1" Text="{Binding AgentPanel.ContextFolder, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="Output folder:" VerticalAlignment="Center" Margin="12,0,6,0" />
                    <TextBox Grid.Column="3" Text="{Binding AgentPanel.OutputFolder, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                    <Button Grid.Column="4" Content="Open context" Margin="8,0,0,0" Padding="8,2" Command="{Binding AgentPanel.OpenContextFolderCommand}" />
                    <Button Grid.Column="5" Content="Open output" Margin="8,0,0,0" Padding="8,2" Command="{Binding AgentPanel.OpenOutputFolderCommand}" />
                </Grid>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Start Agent" Width="110" Command="{Binding AgentPanel.StartCommand}" />
                    <Button Content="Stop Agent" Width="110" Margin="8,0,0,0" Command="{Binding AgentPanel.StopCommand}" />
                    <Button Content="Dismiss" Width="90" Margin="18,0,0,0" Command="{Binding AgentPanel.DismissCommand}" />
                    <Button Content="Copy" Width="90" Margin="8,0,0,0" Command="{Binding AgentPanel.CopyCommand}" />
                </StackPanel>

                <ListBox Grid.Row="3"
                         ItemsSource="{Binding AgentPanel.Suggestions}"
                         SelectedItem="{Binding AgentPanel.SelectedSuggestion}"
                         HorizontalContentAlignment="Stretch"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Time}" Foreground="Gray" />
                                    <TextBlock Text="{Binding Priority}" FontWeight="Bold" Margin="10,0,0,0" />
                                    <TextBlock Text="{Binding Type}" Foreground="DarkSlateBlue" Margin="10,0,0,0" />
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Margin="10,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap" Foreground="#444444" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Grid.Row="4" Text="{Binding AgentPanel.StatusText}" Foreground="Gray" Margin="0,8,0,0" TextWrapping="Wrap" />
            </Grid>
        </TabItem>

        <TabItem Header="Speakers">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding SpeakerPanel.Note}" Foreground="Gray" Margin="0,0,0,8" TextWrapping="Wrap" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding SpeakerPanel.Speakers}"
                         SelectedItem="{Binding SpeakerPanel.SelectedSpeaker}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SampleCount, StringFormat='  samples: {0}'}" Foreground="Gray" />
                                <TextBlock Text="{Binding LastSeenAt, StringFormat='  last seen: {0:yyyy-MM-dd HH:mm}'}" Foreground="Gray" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Rename to:" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox Grid.Column="1" Text="{Binding SpeakerPanel.RenameTo, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Content="Rename" Margin="8,0,0,0" Padding="12,2" Command="{Binding SpeakerPanel.RenameCommand}" />
                    <Button Grid.Column="3" Content="Forget" Margin="8,0,0,0" Padding="12,2" Command="{Binding SpeakerPanel.ForgetCommand}" />
                    <Button Grid.Column="4" Content="Refresh" Margin="8,0,0,0" Padding="12,2" Command="{Binding SpeakerPanel.RefreshCommand}" />
                </Grid>

                <TextBlock Grid.Row="3" Text="{Binding SpeakerPanel.StatusText}" Foreground="Gray" Margin="0,8,0,0" />
            </Grid>
        </TabItem>

        <TabItem Header="Settings">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12" MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Text="Transcript folder" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Settings.TranscriptFolder, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />

                    <CheckBox Content="Enable microphone capture" IsChecked="{Binding Settings.EnableMicCapture}" Margin="0,0,0,6" />
                    <CheckBox Content="Enable system audio capture" IsChecked="{Binding Settings.EnableSystemCapture}" Margin="0,0,0,10" />

                    <TextBlock Text="Default microphone speaker name" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Settings.DefaultMicSpeakerName, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />

                    <TextBlock Text="Whisper model path" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Settings.WhisperModelPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />

                    <TextBlock Text="Speaker model path" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Settings.SpeakerModelPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />

                    <TextBlock Text="Speaker match threshold (0-1)" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Settings.SpeakerMatchThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />

                    <TextBlock Text="Chunk seconds" FontWeight="SemiBold" />
                    <TextBox Text="{Binding Settings.ChunkSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,10" />

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Content="Save settings" Padding="14,4" Command="{Binding Settings.SaveCommand}" />
                        <TextBlock Text="{Binding Settings.SaveStatus}" Foreground="Gray" Margin="12,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <Separator Margin="0,14,0,10" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="Audio devices" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button Content="Refresh audio devices" Padding="12,2" Margin="12,0,0,0" Command="{Binding Settings.RefreshDevicesCommand}" />
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Settings.AudioDevices}" MinHeight="60" MaxHeight="160" />
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Window>
