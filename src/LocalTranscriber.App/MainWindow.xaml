<Window x:Class="LocalTranscriber.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LocalTranscriber" Height="300" Width="420">
    <StackPanel Margin="16" VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="LocalTranscriber" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" />
        <TextBlock Text="Status: Not recording" FontSize="14" Margin="0,12,0,16" HorizontalAlignment="Center" />
        <Button Content="Start placeholder" Width="180" Margin="0,0,0,8" IsEnabled="False" />
        <Button Content="Stop placeholder" Width="180" IsEnabled="False" />
    </StackPanel>
</Window>
