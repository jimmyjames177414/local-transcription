<Window x:Class="LocalTranscriber.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LocalTranscriber.App.Views"
        xmlns:conv="clr-namespace:LocalTranscriber.App.Converters"
        Title="LocalTranscriber"
        Width="1000" Height="640" MinWidth="640" MinHeight="420"
        Background="{StaticResource Brush.Bg.Window}"
        Foreground="{StaticResource Brush.Text.Primary}"
        FontFamily="{StaticResource Font.Ui}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="46" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:ScreenVisibilityConverter x:Key="ScreenVisibility" />
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ═══ Header / title bar ═══ -->
        <Border Grid.Row="0" Background="{StaticResource Brush.Bg.Chrome}"
                BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <Border Grid.Column="0" Width="19" Height="19" CornerRadius="5" Margin="14,0,6,0"
                        Background="{StaticResource Brush.Accent}" VerticalAlignment="Center">
                    <TextBlock Text="LT" FontFamily="{StaticResource Font.Mono}" FontSize="9" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>

                <!-- Nav pills -->
                <ListBox Grid.Column="1" Style="{StaticResource NavPillListBoxStyle}"
                         WindowChrome.IsHitTestVisibleInChrome="True"
                         VerticalAlignment="Center" Margin="6,0,0,0"
                         SelectedIndex="{Binding Session.SelectedScreenIndex, Mode=TwoWay}">
                    <ListBoxItem Content="Meeting" />
                    <ListBoxItem Content="Sessions" />
                    <ListBoxItem Content="Speakers" />
                    <ListBoxItem Content="Settings" />
                </ListBox>

                <!-- Mini privacy pill (small windows) -->
                <Border x:Name="MiniPrivacyPill" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,8,0"
                        CornerRadius="99" Background="{StaticResource Brush.Privacy.Local.Bg}"
                        BorderBrush="{StaticResource Brush.Privacy.Local.Border}" BorderThickness="1" Padding="8,3"
                        Visibility="Collapsed"
                        ToolTip="{Binding AgentPanel.PrivacyLocalText}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⛨" FontSize="9" Foreground="{StaticResource Brush.Privacy.Local}" VerticalAlignment="Center" />
                        <TextBlock Text="local" FontSize="9.5" FontWeight="SemiBold" Foreground="{StaticResource Brush.Privacy.Local.Text}"
                                   Margin="4,0,0,0" VerticalAlignment="Center" />
                        <Ellipse Width="5" Height="5" Fill="{StaticResource Brush.Privacy.Cloud}" Margin="5,0,0,0" VerticalAlignment="Center"
                                 Visibility="{Binding AgentPanel.AgentCloudActive, Converter={StaticResource BoolToVisibility}}" />
                    </StackPanel>
                </Border>

                <!-- Privacy readout: always agrees with the agent panel (same view model) -->
                <Border x:Name="PrivacyReadout" Grid.Column="3" VerticalAlignment="Center" Margin="0,0,12,0"
                        BorderBrush="{StaticResource Brush.Surface.Hi}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="{StaticResource Brush.Privacy.Local.Bg}" Padding="11,5" CornerRadius="7,0,0,7">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource Brush.Privacy.Local}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding AgentPanel.PrivacyLocalText}" FontFamily="{StaticResource Font.Mono}" FontSize="10.5"
                                           Foreground="{StaticResource Brush.Privacy.Local.Text}" Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <Border Width="1" Background="{StaticResource Brush.Surface.Hi}"
                                Visibility="{Binding AgentPanel.AgentCloudActive, Converter={StaticResource BoolToVisibility}}" />
                        <Border Background="{StaticResource Brush.Privacy.Cloud.Bg}" Padding="11,5" CornerRadius="0,7,7,0"
                                Visibility="{Binding AgentPanel.AgentCloudActive, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource Brush.Privacy.Cloud}" VerticalAlignment="Center" />
                                <TextBlock Text="{Binding AgentPanel.PrivacyAgentText}" FontFamily="{StaticResource Font.Mono}" FontSize="10.5"
                                           Foreground="{StaticResource Brush.Privacy.Cloud.Text}" Margin="6,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Recording / idle pill -->
                <Grid Grid.Column="4" VerticalAlignment="Center" Margin="0,0,8,0">
                    <!-- Recording -->
                    <Border CornerRadius="4" Background="{StaticResource Brush.Rec.Bg}"
                            BorderBrush="{StaticResource Brush.Rec.Border}" BorderThickness="1" Padding="9,4,12,4"
                            Visibility="{Binding Session.IsRecording, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Style="{StaticResource PulseDotStyle}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Session.Elapsed}" FontFamily="{StaticResource Font.Mono}" FontSize="11.5"
                                       FontWeight="SemiBold" Foreground="{StaticResource Brush.Rec.Text}" Margin="8,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <!-- Viewing archive (review mode) -->
                    <Border CornerRadius="99" Background="{StaticResource Brush.Accent.Bg}"
                            BorderBrush="{StaticResource Brush.Accent.Border}" BorderThickness="1" Padding="12,4"
                            Visibility="{Binding Session.IsReviewing, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◷" FontSize="10" Foreground="{StaticResource Brush.Accent.Text}" VerticalAlignment="Center" />
                            <TextBlock Text="Viewing archive" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Accent.Text}" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <!-- Idle -->
                    <Border CornerRadius="99" Background="{StaticResource Brush.Bg.Chrome}"
                            BorderBrush="{StaticResource Brush.Surface.Hi}" BorderThickness="1" Padding="12,4"
                            Visibility="{Binding Session.ShowIdleStatusPill, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7" Fill="{StaticResource Brush.Text.Faint}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Session.StatusText}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Brush.Text.Muted}" Margin="7,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Caption buttons -->
                <StackPanel Grid.Column="5" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionButtonStyle}" Content="&#xE921;" Click="Minimize_Click" />
                    <Button x:Name="MaximizeButton" Style="{StaticResource CaptionButtonStyle}" Content="&#xE922;" Click="MaximizeRestore_Click" />
                    <Button Style="{StaticResource CloseCaptionButtonStyle}" Content="&#xE8BB;" Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Screens ═══ -->
        <Grid Grid.Row="1">
            <views:MeetingView Visibility="{Binding Session.SelectedScreenIndex, Converter={StaticResource ScreenVisibility}, ConverterParameter=0}" />
            <views:SessionsView Visibility="{Binding Session.SelectedScreenIndex, Converter={StaticResource ScreenVisibility}, ConverterParameter=1}" />
            <views:SpeakersView Visibility="{Binding Session.SelectedScreenIndex, Converter={StaticResource ScreenVisibility}, ConverterParameter=2}" />
            <views:SettingsView Visibility="{Binding Session.SelectedScreenIndex, Converter={StaticResource ScreenVisibility}, ConverterParameter=3}" />
        </Grid>
    </Grid>
</Window>
