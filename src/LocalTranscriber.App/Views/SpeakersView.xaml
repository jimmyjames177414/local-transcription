<UserControl x:Class="LocalTranscriber.App.Views.SpeakersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Speakers screen per design 4e: roster cards, inline rename, in-card forget confirm. -->
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Text="Voice memory" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Title}" VerticalAlignment="Center" />
                <TextBlock Text="{Binding SpeakerPanel.CountText}" FontSize="11.5" Foreground="{StaticResource Brush.Text.Muted}"
                           Margin="12,0,0,0" VerticalAlignment="Center" />
            </StackPanel>
            <Button Grid.Column="2" Content="⟳ Refresh" Style="{StaticResource SubtleButtonStyle}" Command="{Binding SpeakerPanel.RefreshCommand}" />
        </Grid>

        <!-- Roster -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding SpeakerPanel.Cards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemWidth="304" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="Card" Style="{StaticResource CardBorderStyle}" Margin="0,0,12,12" MinHeight="118">
                            <Grid>
                                <!-- ═ Normal / rename / forget states of a speaker card ═ -->
                                <StackPanel x:Name="SpeakerBody">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="34" Height="34" CornerRadius="10" Background="{StaticResource Brush.Surface.Hi}">
                                            <TextBlock Text="{Binding Initials}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{Binding Badge}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Title}" />
                                            <TextBlock Text="{Binding SubText}" FontSize="10" Foreground="{StaticResource Brush.Text.Muted}" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Normal actions -->
                                    <StackPanel x:Name="NormalActions" Orientation="Horizontal" Margin="0,12,0,0">
                                        <Button Content="Rename" Style="{StaticResource SubtleButtonStyle}" Padding="10,3" FontSize="10.5"
                                                Command="{Binding BeginRenameCommand}" />
                                        <Button Content="Forget…" Padding="6,3" FontSize="10.5" FontWeight="SemiBold" Cursor="Hand"
                                                Foreground="{StaticResource Brush.Text.Muted}" Background="Transparent" BorderThickness="0"
                                                Command="{Binding BeginForgetCommand}" Margin="6,0,0,0" />
                                    </StackPanel>

                                    <!-- Rename editor -->
                                    <StackPanel x:Name="RenameEditor" Margin="0,10,0,0" Visibility="Collapsed">
                                        <TextBox Style="{StaticResource TextInputStyle}"
                                                 Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock FontSize="10" Foreground="{StaticResource Brush.Text.Muted}" TextWrapping="Wrap" Margin="0,6,0,0">
                                            <Run Text="Was " /><Run Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Body}" /><Run Text=" · voice sample kept, so the new name is recognized automatically next time." />
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}" Padding="12,3" FontSize="10.5"
                                                    Command="{Binding ConfirmRenameCommand}" />
                                            <Button Content="Cancel" Padding="8,3" FontSize="10.5" Foreground="{StaticResource Brush.Text.Muted}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding CancelCommand}" Margin="4,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Forget confirm -->
                                    <StackPanel x:Name="ForgetConfirm" Margin="0,10,0,0" Visibility="Collapsed">
                                        <TextBlock Text="Forget this voice? The embedding is deleted from this PC; past transcripts keep the name. This can't be undone."
                                                   FontSize="10.5" Foreground="#FFF0B0B0" TextWrapping="Wrap" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <Button Content="Forget voice" Style="{StaticResource DangerSolidButtonStyle}" Padding="12,3" FontSize="10.5"
                                                    Command="{Binding ConfirmForgetCommand}" />
                                            <Button Content="Keep" Padding="8,3" FontSize="10.5" Foreground="{StaticResource Brush.Text.Muted}"
                                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                                    Command="{Binding CancelCommand}" Margin="4,0,0,0" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Me card note -->
                                    <TextBlock x:Name="MeNote" Text="Rename in Settings → General" FontSize="10"
                                               Foreground="{StaticResource Brush.Text.Hint}" Margin="0,12,0,0" Visibility="Collapsed" />
                                </StackPanel>

                                <!-- ═ Enroll card ═ -->
                                <StackPanel x:Name="EnrollBody" Visibility="Collapsed" VerticalAlignment="Center">
                                    <TextBlock Text="+ Enroll a voice" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brush.Nav.Inactive}" />
                                    <TextBlock FontSize="10.5" Foreground="{StaticResource Brush.Text.Hint}" TextWrapping="Wrap" Margin="0,5,0,0"
                                               Text="Enroll from a WAV sample via the CLI:" />
                                    <TextBlock Text='localtranscriber speakers enroll --name "Ana" --audio sample.wav'
                                               FontFamily="{StaticResource Font.Mono}" FontSize="9.5"
                                               Foreground="{StaticResource Brush.Text.Faint}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding State}" Value="Renaming">
                                <Setter TargetName="NormalActions" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="RenameEditor" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource Brush.Accent}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding State}" Value="ConfirmForget">
                                <Setter TargetName="NormalActions" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="ForgetConfirm" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource Brush.Danger.Border}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="Me">
                                <Setter TargetName="NormalActions" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="MeNote" Property="Visibility" Value="Visible" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="Enroll">
                                <Setter TargetName="SpeakerBody" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="EnrollBody" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Card" Property="Background" Value="Transparent" />
                                <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource Brush.Stroke.Hi}" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock Grid.Row="2" Text="{Binding SpeakerPanel.StatusText}" Style="{StaticResource HintTextStyle}" Margin="0,10,0,0" />
    </Grid>
</UserControl>
