<UserControl x:Class="LocalTranscriber.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:LocalTranscriber.App.Converters">
    <!-- Settings per design 4f: left section nav, grouped fields, save feedback. -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <conv:ScreenVisibilityConverter x:Key="SectionVisibility" />
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Body}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Title}" />
        </Style>
        <Style x:Key="SectionSub" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Muted}" />
            <Setter Property="Margin" Value="0,2,0,14" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="SettingsNavListBox" TargetType="ListBox" BasedOn="{StaticResource NavPillListBoxStyle}">
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="Foreground" Value="{StaticResource Brush.Nav.Inactive}" />
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="Margin" Value="0,0,0,2" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" CornerRadius="7" Padding="12,7" Background="Transparent">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Brush.Stroke.Soft}" />
                                            <Setter Property="Foreground" Value="White" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Trigger>
                                        <MultiTrigger>
                                            <MultiTrigger.Conditions>
                                                <Condition Property="IsMouseOver" Value="True" />
                                                <Condition Property="IsSelected" Value="False" />
                                            </MultiTrigger.Conditions>
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
                                        </MultiTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="172" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Section nav -->
        <Border Grid.Column="0" BorderBrush="{StaticResource Brush.Stroke.Soft}" BorderThickness="0,0,1,0" Padding="10,16">
            <ListBox Style="{StaticResource SettingsNavListBox}" ItemsSource="{Binding Settings.Sections}"
                     SelectedIndex="{Binding Settings.SelectedSectionIndex, Mode=TwoWay}" />
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="26,20">
                <Grid MaxWidth="560" HorizontalAlignment="Left">

                    <!-- ═ General ═ -->
                    <StackPanel Visibility="{Binding Settings.SelectedSectionIndex, Converter={StaticResource SectionVisibility}, ConverterParameter=0}">
                        <TextBlock Text="General" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Everyday options. Model paths and tuning live under Models &amp; Advanced." Style="{StaticResource SectionSub}" />

                        <TextBlock Text="Transcript folder" Style="{StaticResource FieldLabel}" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource PathInputStyle}"
                                     Text="{Binding Settings.TranscriptFolder, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="Browse…" Style="{StaticResource SubtleButtonStyle}" Margin="8,0,0,0"
                                    Click="BrowseTranscriptFolder_Click" />
                        </Grid>

                        <TextBlock Text="Your name on the mic track" Style="{StaticResource FieldLabel}" />
                        <TextBox Style="{StaticResource TextInputStyle}" Width="240" HorizontalAlignment="Left" Margin="0,0,0,14"
                                 Text="{Binding Settings.DefaultMicSpeakerName, UpdateSourceTrigger=PropertyChanged}" />

                        <CheckBox Content="Capture microphone" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"
                                  IsChecked="{Binding Settings.EnableMicCapture}" />
                        <CheckBox Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,10"
                                  IsChecked="{Binding Settings.EnableSystemCapture}">
                            <TextBlock><Run Text="Capture system audio " /><Run Text="(other participants)" Foreground="{StaticResource Brush.Text.Muted}" FontSize="11" /></TextBlock>
                        </CheckBox>
                        <CheckBox Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,16"
                                  IsChecked="{Binding Settings.FilterNonSpeech}">
                            <TextBlock><Run Text="Speech only " /><Run Text="— drop &quot;(engine revving)&quot; style annotations" Foreground="{StaticResource Brush.Text.Muted}" FontSize="11" /></TextBlock>
                        </CheckBox>

                        <Border Height="1" Background="{StaticResource Brush.Stroke.Soft}" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Speaker match threshold" Style="{StaticResource FieldLabel}" />
                            <TextBlock Text="{Binding Settings.SpeakerMatchThreshold, StringFormat=0.00}" FontFamily="{StaticResource Font.Mono}"
                                       FontSize="11.5" FontWeight="SemiBold" Foreground="{StaticResource Brush.Accent.Text}" HorizontalAlignment="Right" />
                        </Grid>
                        <Slider Minimum="0" Maximum="1" TickFrequency="0.01" IsSnapToTickEnabled="True"
                                Value="{Binding Settings.SpeakerMatchThreshold}" />
                        <Grid Margin="0,2,0,0">
                            <TextBlock Text="looser — merges similar voices" FontSize="9.5" Foreground="{StaticResource Brush.Text.Hint}" />
                            <TextBlock Text="stricter — more &quot;possibly&quot; labels" FontSize="9.5" Foreground="{StaticResource Brush.Text.Hint}" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>

                    <!-- ═ Audio ═ -->
                    <StackPanel Visibility="{Binding Settings.SelectedSectionIndex, Converter={StaticResource SectionVisibility}, ConverterParameter=1}">
                        <TextBlock Text="Audio" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Devices the app can capture. Voice-assistant devices are picked on the Meeting screen (devices ▾)." Style="{StaticResource SectionSub}" />
                        <Button Content="⟳ Refresh audio devices" Style="{StaticResource SubtleButtonStyle}" HorizontalAlignment="Left"
                                Command="{Binding Settings.RefreshDevicesCommand}" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding Settings.AudioDevices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontFamily="{StaticResource Font.Mono}" FontSize="10.5"
                                               Foreground="{StaticResource Brush.Text.Body}" Margin="0,0,0,4" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- ═ Models ═ -->
                    <StackPanel Visibility="{Binding Settings.SelectedSectionIndex, Converter={StaticResource SectionVisibility}, ConverterParameter=2}">
                        <TextBlock Text="Models" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Local model files. Download once with ./scripts/setup.ps1 -DownloadModels." Style="{StaticResource SectionSub}" />

                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Whisper model (transcription)" Style="{StaticResource FieldLabel}" />
                            <TextBlock Text="{Binding Settings.WhisperModelStatus}" FontSize="10.5" HorizontalAlignment="Right"
                                       Foreground="{StaticResource Brush.Privacy.Local.Text}" />
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource PathInputStyle}"
                                     Text="{Binding Settings.WhisperModelPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="Browse…" Style="{StaticResource SubtleButtonStyle}" Margin="8,0,0,0"
                                    Click="BrowseWhisperModel_Click" />
                        </Grid>

                        <Grid Margin="0,0,0,4">
                            <TextBlock Text="Speaker model (diarization / voice ID)" Style="{StaticResource FieldLabel}" />
                            <TextBlock Text="{Binding Settings.SpeakerModelStatus}" FontSize="10.5" HorizontalAlignment="Right"
                                       Foreground="{StaticResource Brush.Privacy.Local.Text}" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource PathInputStyle}"
                                     Text="{Binding Settings.SpeakerModelPath, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="Browse…" Style="{StaticResource SubtleButtonStyle}" Margin="8,0,0,0"
                                    Click="BrowseSpeakerModel_Click" />
                        </Grid>
                    </StackPanel>

                    <!-- ═ Assistant & privacy ═ -->
                    <StackPanel Visibility="{Binding Settings.SelectedSectionIndex, Converter={StaticResource SectionVisibility}, ConverterParameter=3}">
                        <TextBlock Text="Assistant &amp; privacy" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="The AI assistant is the only feature that can send anything to the cloud, and only when enabled. Transcription is always local." Style="{StaticResource SectionSub}" />

                        <CheckBox Content="Enable assistant" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,12"
                                  IsChecked="{Binding AgentPanel.AgentEnabled}" />

                        <TextBlock Text="Backend" Style="{StaticResource FieldLabel}" />
                        <ComboBox Width="160" HorizontalAlignment="Left" Margin="0,0,0,4"
                                  Style="{StaticResource ComboBoxStyle}"
                                  ItemsSource="{Binding AgentPanel.Providers}" SelectedItem="{Binding AgentPanel.SelectedProvider}" />
                        <TextBlock Text="openai = cloud realtime voice/text; claude-cli = local Claude Code CLI in a workspace; hybrid = Claude does the thinking &amp; notes, OpenAI speaks the replies."
                                   FontSize="10" Foreground="{StaticResource Brush.Text.Hint}" Margin="0,0,0,12" TextWrapping="Wrap" />

                        <!-- Claude CLI workspace picker (claude-cli + hybrid backends) -->
                        <StackPanel Visibility="{Binding AgentPanel.UsesClaudeBrain, Converter={StaticResource BoolToVisibility}}">
                            <CheckBox Content="Run in WSL" Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"
                                      IsChecked="{Binding AgentPanel.UseWsl}" />
                            <TextBlock Text="Launch the Claude CLI inside a WSL distro instead of native Windows. Use this when your repos live in WSL — the workspace below is then a Linux path."
                                       FontSize="10" Foreground="{StaticResource Brush.Text.Hint}" Margin="0,0,0,10" TextWrapping="Wrap" />

                            <!-- WSL distro (only when Run in WSL is on) -->
                            <StackPanel Visibility="{Binding AgentPanel.UseWsl, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="WSL distro" Style="{StaticResource FieldLabel}" />
                                <TextBox Style="{StaticResource PathInputStyle}" Margin="0,0,0,4"
                                         Text="{Binding AgentPanel.WslDistro, UpdateSourceTrigger=LostFocus}" />
                                <TextBlock Text="e.g. Ubuntu-22.04. Leave blank to use the default distro (wsl -l)."
                                           FontSize="10" Foreground="{StaticResource Brush.Text.Hint}" Margin="0,0,0,10" TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBlock Text="Workspace folder" Style="{StaticResource FieldLabel}" />
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource PathInputStyle}"
                                         Text="{Binding AgentPanel.WorkspaceFolder, UpdateSourceTrigger=PropertyChanged}" />
                                <!-- The Windows folder picker can't choose Linux paths, so hide it in WSL mode. -->
                                <Button Grid.Column="1" Content="Browse…" Style="{StaticResource SubtleButtonStyle}" Margin="8,0,0,0"
                                        Click="BrowseWorkspaceFolder_Click"
                                        Visibility="{Binding AgentPanel.UseWsl, Converter={StaticResource InverseBoolToVisibility}}" />
                            </Grid>
                            <!-- WSL: the Browse button is hidden because the Windows picker can't navigate Linux paths. -->
                            <TextBlock Text="Type the Linux workspace path (e.g. /home/you/repos) — the Browse picker is hidden because the Windows folder dialog can't navigate WSL paths. Trust the folder once in WSL. Full-agent mode asks for consent on first connect, then can edit files and run commands here."
                                       Visibility="{Binding AgentPanel.UseWsl, Converter={StaticResource BoolToVisibility}}"
                                       FontSize="10" Foreground="{StaticResource Brush.Text.Hint}" Margin="0,0,0,12" TextWrapping="Wrap" />
                            <TextBlock Text="The CLI runs here and reads that project's CLAUDE.md, files, memory, and MCP tools. Full-agent mode asks for consent on first connect, then can edit files and run commands here."
                                       Visibility="{Binding AgentPanel.UseWsl, Converter={StaticResource InverseBoolToVisibility}}"
                                       FontSize="10" Foreground="{StaticResource Brush.Text.Hint}" Margin="0,0,0,12" TextWrapping="Wrap" />

                            <TextBlock Text="Model" Style="{StaticResource FieldLabel}" />
                            <TextBox Style="{StaticResource TextInputStyle}" Width="240" HorizontalAlignment="Left" Margin="0,0,0,4"
                                     Text="{Binding AgentPanel.ClaudeModel, UpdateSourceTrigger=LostFocus}" />
                            <TextBlock Text="Model alias passed to the CLI (e.g. haiku for fast meeting help). Leave blank for the CLI default."
                                       FontSize="10" Foreground="{StaticResource Brush.Text.Hint}" Margin="0,0,0,12" TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock Text="Voice mode" Style="{StaticResource FieldLabel}" />
                        <ComboBox Width="160" HorizontalAlignment="Left" Margin="0,0,0,4"
                                  Style="{StaticResource ComboBoxStyle}"
                                  ItemsSource="{Binding AgentPanel.VoiceModes}" SelectedItem="{Binding AgentPanel.SelectedVoiceMode}" />
                        <TextBlock Text="hybrid sends text only; pushToTalk/continuous stream your mic (asks for consent)."
                                   FontSize="10" Foreground="{StaticResource Brush.Text.Hint}" Margin="0,0,0,12" />

                        <Border Height="1" Background="{StaticResource Brush.Stroke.Soft}" Margin="0,0,0,12" />
                        <CheckBox Style="{StaticResource ToggleSwitchStyle}" Margin="0,0,0,4"
                                  IsChecked="{Binding Settings.AllowMicStreaming}">
                            <TextBlock><Run Text="Allow mic streaming " /><Run Text="(stored consent for pushToTalk / continuous)" Foreground="{StaticResource Brush.Text.Muted}" FontSize="11" /></TextBlock>
                        </CheckBox>
                        <TextBlock Text="Turning this off makes the next switch to a streaming mode ask for consent again. Meeting/system audio is never sent in any mode."
                                   FontSize="10" Foreground="{StaticResource Brush.Text.Hint}" Margin="0,0,0,12" TextWrapping="Wrap" />

                        <Border Height="1" Background="{StaticResource Brush.Stroke.Soft}" Margin="0,0,0,12" />
                        <TextBlock Text="Context packs folder" Style="{StaticResource FieldLabel}" />
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource PathInputStyle}"
                                     Text="{Binding AgentPanel.ContextFolder, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="Open ↗" Style="{StaticResource SubtleButtonStyle}" Margin="8,0,0,0"
                                    Command="{Binding AgentPanel.OpenContextFolderCommand}" />
                        </Grid>
                        <TextBlock Text="Assistant output folder (notes, captions)" Style="{StaticResource FieldLabel}" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Style="{StaticResource PathInputStyle}"
                                     Text="{Binding AgentPanel.OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1" Content="Open ↗" Style="{StaticResource SubtleButtonStyle}" Margin="8,0,0,0"
                                    Command="{Binding AgentPanel.OpenOutputFolderCommand}" />
                        </Grid>
                    </StackPanel>

                    <!-- ═ Integrations (design 4m) ═ -->
                    <StackPanel Visibility="{Binding Settings.SelectedSectionIndex, Converter={StaticResource SectionVisibility}, ConverterParameter=4}">
                        <TextBlock Text="Integrations" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Make sessions readable by your AI tools. Everything below is file-based and local." Style="{StaticResource SectionSub}" />

                        <!-- Minutes card -->
                        <Border Background="{StaticResource Brush.Bg.Chrome}" BorderBrush="{StaticResource Brush.Surface.Hi}"
                                BorderThickness="1" CornerRadius="12" MaxWidth="620" HorizontalAlignment="Left">
                            <StackPanel>
                                <Border BorderBrush="{StaticResource Brush.Stroke.Soft}" BorderThickness="0,0,0,1" Padding="15,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="8" Background="{StaticResource Brush.Bg.Notes}"
                                                BorderBrush="{StaticResource Brush.Surface.Hi}" BorderThickness="1" Margin="0,0,10,0">
                                            <TextBlock Text="min" FontFamily="{StaticResource Font.Mono}" FontSize="10" FontWeight="Bold"
                                                       Foreground="{StaticResource Brush.Privacy.Cloud.Text}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Title}">
                                                <Run Text="Minutes" /><Run Text=" — conversation memory for Claude &amp; other agents" FontWeight="Normal" FontSize="10" Foreground="{StaticResource Brush.Text.Hint}" />
                                            </TextBlock>
                                            <TextBlock Text="Publishes each session as markdown + frontmatter into your Minutes meetings folder"
                                                       FontSize="10" Foreground="{StaticResource Brush.Text.Muted}" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" VerticalAlignment="Center"
                                                  IsChecked="{Binding Settings.ExportMinutesOnStop}"
                                                  ToolTip="Export each session as minutes markdown when it stops" />
                                    </Grid>
                                </Border>
                                <StackPanel Margin="15,12,15,14">
                                    <Grid Margin="0,0,0,11">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Meetings folder" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.Text.Body}" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Style="{StaticResource PathInputStyle}"
                                                 Text="{Binding Settings.MinutesFolder, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button Grid.Column="2" Content="Browse…" Style="{StaticResource SubtleButtonStyle}" Padding="11,4"
                                                FontSize="10.5" Margin="8,0,0,0" Click="BrowseMinutesFolder_Click" />
                                    </Grid>
                                    <Grid Margin="0,0,0,11">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="What's included" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.Text.Body}" VerticalAlignment="Top" Margin="0,2,0,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock FontSize="11" Foreground="{StaticResource Brush.Nav.Inactive}" Margin="0,0,0,5"><Run Text="✓" Foreground="{StaticResource Brush.Privacy.Local.Text}" /><Run Text=" Transcript + speaker names" /></TextBlock>
                                            <TextBlock FontSize="11" Foreground="{StaticResource Brush.Nav.Inactive}" Margin="0,0,0,5"><Run Text="✓" Foreground="{StaticResource Brush.Privacy.Local.Text}" /><Run Text=" AI notes → frontmatter " /><Run Text="decisions · action_items" FontFamily="{StaticResource Font.Mono}" FontSize="9" Foreground="{StaticResource Brush.Text.Faint}" /></TextBlock>
                                            <TextBlock FontSize="11" Foreground="{StaticResource Brush.Nav.Inactive}" Margin="0,0,0,5"><Run Text="✓" Foreground="{StaticResource Brush.Privacy.Local.Text}" /><Run Text=" Title, date, duration" /></TextBlock>
                                            <TextBlock FontSize="11" Foreground="{StaticResource Brush.Nav.Inactive}"><Run Text="✗" Foreground="{StaticResource Brush.Text.Faint}" /><Run Text=" Audio is never copied — transcript only" /></TextBlock>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,0,0,11">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Live feed" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Brush.Text.Body}" VerticalAlignment="Top" Margin="0,2,0,0" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Agents can tail the live transcript JSONL mid-meeting (local file reads only):"
                                                       FontSize="11" Foreground="{StaticResource Brush.Nav.Inactive}" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Settings.LiveFeedPathText}" FontFamily="{StaticResource Font.Mono}" FontSize="9.5"
                                                       Foreground="{StaticResource Brush.Text.Faint}" TextWrapping="Wrap" Margin="0,3,0,0" />
                                        </StackPanel>
                                    </Grid>
                                    <!-- Status strip -->
                                    <Border CornerRadius="8" Background="{StaticResource Brush.Privacy.Local.Bg}"
                                            BorderBrush="{StaticResource Brush.Privacy.Local.Border}" BorderThickness="1" Padding="11,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Settings.MinutesStatusText}" FontSize="10.5"
                                                       Foreground="{StaticResource Brush.Text.Muted}" VerticalAlignment="Center" TextWrapping="Wrap" />
                                            <Button Grid.Column="1" Content="Sync all now" Style="{StaticResource SubtleButtonStyle}" Padding="10,3"
                                                    FontSize="10.5" Margin="9,0,0,0" Command="{Binding Settings.SyncAllNowCommand}" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- MCP server row -->
                        <Border Background="{StaticResource Brush.Bg.Chrome}" BorderBrush="{StaticResource Brush.Surface.Hi}"
                                BorderThickness="1" CornerRadius="12" MaxWidth="620" HorizontalAlignment="Left" Padding="15,10" Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="8" Background="{StaticResource Brush.Bg.Notes}"
                                        BorderBrush="{StaticResource Brush.Surface.Hi}" BorderThickness="1" Margin="0,0,10,0">
                                    <TextBlock Text="⌁" FontSize="12" Foreground="{StaticResource Brush.Accent.Text}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Title}">
                                        <Run Text="MCP server" /><Run Text=" — built in" FontWeight="Normal" FontSize="10" Foreground="{StaticResource Brush.Text.Hint}" />
                                    </TextBlock>
                                    <TextBlock Text="Claude Code / Desktop can control recording and query sessions directly. Connect via stdio:"
                                               FontSize="10" Foreground="{StaticResource Brush.Text.Muted}" />
                                    <TextBlock Text="dotnet run --project src\LocalTranscriber.Mcp" FontFamily="{StaticResource Font.Mono}"
                                               FontSize="9.5" Foreground="{StaticResource Brush.Text.Faint}" Margin="0,2,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- ═ Advanced ═ -->
                    <StackPanel Visibility="{Binding Settings.SelectedSectionIndex, Converter={StaticResource SectionVisibility}, ConverterParameter=5}">
                        <TextBlock Text="Advanced" Style="{StaticResource SectionTitle}" />
                        <TextBlock Text="Transcription tuning. Defaults are sensible; change with care." Style="{StaticResource SectionSub}" />
                        <TextBlock Text="Chunk seconds" Style="{StaticResource FieldLabel}" />
                        <TextBox Style="{StaticResource TextInputStyle}" Width="120" HorizontalAlignment="Left"
                                 Text="{Binding Settings.ChunkSeconds, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Audio is transcribed in chunks of this length; smaller = lower latency, more cuts mid-sentence."
                                   FontSize="10" Foreground="{StaticResource Brush.Text.Hint}" Margin="0,4,0,0" />
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <!-- Save bar -->
            <Border Grid.Row="1" BorderBrush="{StaticResource Brush.Stroke.Soft}" BorderThickness="0,1,0,0" Padding="26,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Save" Style="{StaticResource PrimaryButtonStyle}" Padding="18,8"
                            Command="{Binding Settings.SaveCommand}" />
                    <TextBlock Grid.Column="1" Text="{Binding Settings.SaveStatus}" FontSize="11.5"
                               Foreground="{StaticResource Brush.Privacy.Local.Text}" Margin="12,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="Changes apply to the next session" FontSize="10.5"
                               Foreground="{StaticResource Brush.Text.Hint}" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
