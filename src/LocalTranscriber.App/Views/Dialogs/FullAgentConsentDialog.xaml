<Window x:Class="LocalTranscriber.App.Views.Dialogs.FullAgentConsentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Let the assistant edit this workspace?"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="Height" Width="470" ResizeMode="NoResize" ShowInTaskbar="False">

    <Border Background="{StaticResource Brush.Bg.Chrome}" BorderBrush="{StaticResource Brush.Stroke.Hi}"
            BorderThickness="1" CornerRadius="14" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.5" />
        </Border.Effect>
        <StackPanel>
            <!-- Title -->
            <StackPanel Margin="18,16,18,12">
                <TextBlock Text="Let the assistant edit this workspace?" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Text.Title}" />
                <TextBlock Text="The Claude CLI runs as a full agent in the folder you chose."
                           FontSize="11" Foreground="{StaticResource Brush.Text.Muted}" Margin="0,2,0,0" />
            </StackPanel>
            <Border Height="1" Background="{StaticResource Brush.Stroke}" />

            <!-- What full-agent mode means -->
            <StackPanel Margin="18,14,18,4">
                <TextBlock FontSize="12" Foreground="{StaticResource Brush.Text.Body}" TextWrapping="Wrap" LineHeight="18">
                    In full-agent mode the assistant can <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Title}">create, edit, and delete files</Run>
                    and <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Title}">run commands</Run> in the workspace, without asking each time.
                </TextBlock>
                <Border Background="{StaticResource Brush.Bg.Notes}" CornerRadius="8" Padding="11,8" Margin="0,10,0,0"
                        BorderBrush="{StaticResource Brush.Surface.Hi}" BorderThickness="1">
                    <TextBlock x:Name="WorkspaceText" FontFamily="{StaticResource Font.Mono}" FontSize="10.5"
                               Foreground="{StaticResource Brush.Text.Body}" TextWrapping="Wrap" />
                </Border>
                <TextBlock FontSize="10.5" Foreground="{StaticResource Brush.Text.Hint}" TextWrapping="Wrap" Margin="0,8,0,0">
                    Decline to keep it <Run FontWeight="SemiBold">read-only</Run> — it can still answer questions and read files, but cannot change anything.
                </TextBlock>
            </StackPanel>

            <!-- Consent -->
            <Border x:Name="ConsentBox" Margin="18,12,18,12" Padding="13,11" CornerRadius="10"
                    Background="{StaticResource Brush.Privacy.Cloud.Bg}" BorderBrush="#FF4A4234" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="ConsentCheck" VerticalAlignment="Top" Margin="0,2,9,0"
                              Checked="Consent_Changed" Unchecked="Consent_Changed" />
                    <TextBlock FontSize="11" Foreground="{StaticResource Brush.Text.Body}" TextWrapping="Wrap" MaxWidth="370">
                        I understand the assistant may <Run FontWeight="SemiBold">modify files and run commands</Run> in this workspace.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,14,14">
                <Button Content="Keep read-only" Style="{StaticResource SubtleButtonStyle}" Padding="16,8" Click="Decline_Click" />
                <Button x:Name="AllowButton" Content="Allow edits &amp; commands" Style="{StaticResource PrimaryButtonStyle}"
                        Margin="8,0,0,0" IsEnabled="False" Click="Allow_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
