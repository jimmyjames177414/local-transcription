<Window x:Class="LocalTranscriber.App.Views.Dialogs.GenerateNotesPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mdxaml="clr-namespace:MdXaml;assembly=MdXaml"
        Title="Generated meeting notes"
        WindowStartupLocation="CenterOwner"
        Width="780" Height="700" MinWidth="480" MinHeight="360"
        Background="{StaticResource Brush.Bg.Chrome}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Generated meeting notes" FontSize="15" FontWeight="SemiBold"
                   Foreground="{StaticResource Brush.Text.Title}" Margin="0,0,0,4" />
        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="10.5" Margin="0,0,0,10"
                   Foreground="{StaticResource Brush.Text.Hint}"
                   Text="Preview only — nothing is saved to your notes or minutes until you click Save. Mermaid diagrams appear as code here; they render as diagrams once the saved .md is opened in a Mermaid-aware viewer." />

        <Border Grid.Row="2" BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1" CornerRadius="8"
                Background="{StaticResource Brush.Bg.Notes}">
            <Grid>
                <!-- Rendered markdown (default) -->
                <mdxaml:MarkdownScrollViewer x:Name="RenderedView"
                                             Foreground="{StaticResource Brush.Text.Body}"
                                             Background="{StaticResource Brush.Bg.Notes}"
                                             Padding="12,10"
                                             FontSize="12"
                                             VerticalScrollBarVisibility="Auto">
                    <mdxaml:MarkdownScrollViewer.MarkdownStyle>
                        <Style TargetType="FlowDocument">
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Body}" />
                            <Setter Property="Background" Value="{StaticResource Brush.Bg.Notes}" />
                            <Setter Property="FontFamily" Value="{StaticResource Font.Ui}" />
                            <Setter Property="FontSize" Value="12" />
                        </Style>
                    </mdxaml:MarkdownScrollViewer.MarkdownStyle>
                </mdxaml:MarkdownScrollViewer>

                <!-- Raw markdown (toggle) -->
                <TextBox x:Name="RawView" Visibility="Collapsed" IsReadOnly="True"
                         FontFamily="{StaticResource Font.Mono}" FontSize="11"
                         Background="{StaticResource Brush.Bg.Notes}" Foreground="{StaticResource Brush.Text.Body}"
                         BorderThickness="0" Padding="12,10"
                         TextWrapping="Wrap" AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" />
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ToggleRawButton" Content="View raw" Style="{StaticResource SubtleButtonStyle}"
                    Padding="14,7" Margin="0,0,8,0" Click="ToggleRaw_Click" />
            <Button Content="Copy" Style="{StaticResource NeutralButtonStyle}"
                    Padding="14,7" Margin="0,0,8,0" Click="Copy_Click" />
            <Button Content="Close" Style="{StaticResource SubtleButtonStyle}"
                    Padding="14,7" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="Save…" Style="{StaticResource PrimaryButtonStyle}"
                    Padding="16,7" IsDefault="True" Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
