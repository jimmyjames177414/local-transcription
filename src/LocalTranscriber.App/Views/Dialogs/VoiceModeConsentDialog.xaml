<Window x:Class="LocalTranscriber.App.Views.Dialogs.VoiceModeConsentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="How should the assistant hear you?"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="Height" Width="470" ResizeMode="NoResize" ShowInTaskbar="False">

    <Border Background="{StaticResource Brush.Bg.Chrome}" BorderBrush="{StaticResource Brush.Stroke.Hi}"
            BorderThickness="1" CornerRadius="14" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.5" />
        </Border.Effect>
        <StackPanel>
            <!-- Title -->
            <StackPanel Margin="18,16,18,12">
                <TextBlock Text="How should the assistant hear you?" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Text.Title}" />
                <TextBlock Text="Meeting &amp; system audio never leave this PC in any mode."
                           FontSize="11" Foreground="{StaticResource Brush.Text.Muted}" Margin="0,2,0,0" />
            </StackPanel>
            <Border Height="1" Background="{StaticResource Brush.Stroke}" />

            <!-- Mode cards -->
            <StackPanel Margin="14,12,14,0">
                <StackPanel.Resources>
                    <Style x:Key="ModeCard" TargetType="Border">
                        <Setter Property="CornerRadius" Value="10" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Surface.Hi}" />
                        <Setter Property="Padding" Value="13,11" />
                        <Setter Property="Margin" Value="0,0,0,8" />
                    </Style>
                    <Style x:Key="ModeRadio" TargetType="RadioButton">
                        <Setter Property="VerticalAlignment" Value="Top" />
                        <Setter Property="Margin" Value="0,2,11,0" />
                    </Style>
                </StackPanel.Resources>

                <!-- Hybrid -->
                <Border x:Name="HybridCard" Style="{StaticResource ModeCard}">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="HybridRadio" Style="{StaticResource ModeRadio}" GroupName="Mode"
                                     Checked="Mode_Checked" />
                        <StackPanel MaxWidth="370">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Hybrid" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Title}" />
                                <Border Background="{StaticResource Brush.Privacy.Local.Bg}" CornerRadius="4" Padding="6,1" Margin="7,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="AUDIO STAYS LOCAL" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource Brush.Privacy.Local.Text}" />
                                </Border>
                                <TextBlock Text="recommended" FontSize="9.5" Foreground="{StaticResource Brush.Text.Hint}" Margin="7,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock FontSize="10.5" Foreground="{StaticResource Brush.Nav.Inactive}" TextWrapping="Wrap" Margin="0,3,0,0">
                                Hold to talk → transcribed <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Body}">on this PC</Run> → only the <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Body}">text</Run> is sent.
                            </TextBlock>
                            <TextBlock Text="🎙 → whisper (local) → &quot;text&quot; → cloud" FontFamily="{StaticResource Font.Mono}"
                                       FontSize="9.5" Foreground="#FF4F7A63" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Push to talk -->
                <Border x:Name="PushCard" Style="{StaticResource ModeCard}">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="PushRadio" Style="{StaticResource ModeRadio}" GroupName="Mode"
                                     Checked="Mode_Checked" />
                        <StackPanel MaxWidth="370">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Push to talk" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Title}" />
                                <Border Background="{StaticResource Brush.Privacy.Cloud.Bg}" CornerRadius="4" Padding="6,1" Margin="7,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="MIC STREAMS WHILE HELD" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource Brush.Privacy.Cloud.Text}" />
                                </Border>
                            </StackPanel>
                            <TextBlock FontSize="10.5" Foreground="{StaticResource Brush.Nav.Inactive}" TextWrapping="Wrap" Margin="0,3,0,0">
                                Your mic audio streams to OpenAI <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Body}">only while the button is held</Run>. Better voice quality, faster replies.
                            </TextBlock>
                            <TextBlock Text="🎙 → ~audio~ → cloud (while held)" FontFamily="{StaticResource Font.Mono}"
                                       FontSize="9.5" Foreground="#FF8A7038" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Continuous -->
                <Border x:Name="ContinuousCard" Style="{StaticResource ModeCard}">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="ContinuousRadio" Style="{StaticResource ModeRadio}" GroupName="Mode"
                                     Checked="Mode_Checked" />
                        <StackPanel MaxWidth="370">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Continuous" FontSize="12.5" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Title}" />
                                <Border Background="{StaticResource Brush.Privacy.Cloud.Bg}" CornerRadius="4" Padding="6,1" Margin="7,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="MIC ALWAYS STREAMING" FontSize="9" FontWeight="SemiBold" Foreground="{StaticResource Brush.Privacy.Cloud.Text}" />
                                </Border>
                            </StackPanel>
                            <TextBlock FontSize="10.5" Foreground="{StaticResource Brush.Nav.Inactive}" TextWrapping="Wrap" Margin="0,3,0,0">
                                Hands-free with barge-in — the assistant stops when you speak. <Run FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Body}">Headphones strongly recommended.</Run>
                            </TextBlock>
                            <TextBlock Text="🎙 → ~audio~ → cloud (always on)" FontFamily="{StaticResource Font.Mono}"
                                       FontSize="9.5" Foreground="#FF8A7038" Margin="0,4,0,0" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Consent -->
            <Border x:Name="ConsentBox" Margin="14,2,14,12" Padding="13,11" CornerRadius="10"
                    Background="{StaticResource Brush.Privacy.Cloud.Bg}" BorderBrush="#FF4A4234" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <CheckBox x:Name="ConsentCheck" VerticalAlignment="Top" Margin="0,2,9,0"
                              Checked="Consent_Changed" Unchecked="Consent_Changed" />
                    <TextBlock FontSize="11" Foreground="{StaticResource Brush.Text.Body}" TextWrapping="Wrap" MaxWidth="370">
                        I understand <Run FontWeight="SemiBold">my microphone audio</Run> will stream to OpenAI in this mode. Meeting audio is never sent.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,14,14">
                <Button Content="Stay on Hybrid" Style="{StaticResource SubtleButtonStyle}" Padding="16,8" Click="Cancel_Click" />
                <Button x:Name="AllowButton" Content="Allow mic streaming" Style="{StaticResource PrimaryButtonStyle}"
                        Margin="8,0,0,0" IsEnabled="False" Click="Allow_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
