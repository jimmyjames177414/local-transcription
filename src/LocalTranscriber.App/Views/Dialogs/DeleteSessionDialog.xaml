<Window x:Class="LocalTranscriber.App.Views.Dialogs.DeleteSessionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Delete session"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="Height" Width="450" ResizeMode="NoResize" ShowInTaskbar="False">

    <Border Background="{StaticResource Brush.Bg.Chrome}" BorderBrush="{StaticResource Brush.Stroke.Hi}"
            BorderThickness="1" CornerRadius="14" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.5" />
        </Border.Effect>
        <StackPanel>
            <StackPanel Margin="18,16,18,10">
                <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource Brush.Text.Title}" />
                <TextBlock Text="These files are removed from this PC. There is no recycle bin for them."
                           FontSize="11" Foreground="{StaticResource Brush.Text.Muted}" Margin="0,3,0,0" TextWrapping="Wrap" />
            </StackPanel>

            <!-- Exact file list -->
            <Border Margin="16,0" Padding="13,10" CornerRadius="9"
                    Background="{StaticResource Brush.Bg.Panel}" BorderBrush="{StaticResource Brush.Stroke}" BorderThickness="1">
                <ItemsControl x:Name="FileList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontFamily="{StaticResource Font.Mono}" FontSize="10.5" LineHeight="18">
                                <Run Text="{Binding Name, Mode=OneWay}" Foreground="{StaticResource Brush.Text.Body}" /><Run
                                    Text="{Binding SizeText, Mode=OneWay}" Foreground="{StaticResource Brush.Text.Faint}" />
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="18,10,18,0">
                <TextBlock Text="✓" FontSize="10.5" Foreground="{StaticResource Brush.Privacy.Local.Text}" Margin="0,0,7,0" VerticalAlignment="Top" />
                <TextBlock x:Name="VoiceMemoryText" FontSize="10.5" Foreground="{StaticResource Brush.Privacy.Local.Text}"
                           TextWrapping="Wrap" MaxWidth="370" />
            </StackPanel>

            <CheckBox x:Name="RemoveMinutesCheck" Style="{StaticResource ToggleSwitchStyle}" Margin="18,10,18,0" FontSize="11"
                      Visibility="Collapsed" Content="Also remove from meetings folder (minutes export)" />

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,16,14">
                <Button Content="Cancel" Style="{StaticResource SubtleButtonStyle}" Padding="16,8" IsCancel="True" />
                <!-- Hold-to-delete: fill animates over 800 ms; completes -> confirm. -->
                <Border x:Name="HoldButton" Margin="8,0,0,0" CornerRadius="8" Background="{StaticResource Brush.Danger.Deep}"
                        Cursor="Hand" ClipToBounds="True"
                        PreviewMouseLeftButtonDown="Hold_Down" PreviewMouseLeftButtonUp="Hold_Up"
                        MouseLeave="Hold_Abort" LostMouseCapture="Hold_Abort">
                    <Grid>
                        <Rectangle x:Name="HoldFill" Fill="#40000000" HorizontalAlignment="Stretch" RenderTransformOrigin="0,0.5">
                            <Rectangle.RenderTransform>
                                <ScaleTransform x:Name="HoldFillScale" ScaleX="0" />
                            </Rectangle.RenderTransform>
                        </Rectangle>
                        <TextBlock Text="Hold to delete…" FontSize="12" FontWeight="SemiBold" Foreground="White"
                                   Margin="16,8" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
