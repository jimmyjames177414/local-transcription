<Window x:Class="LocalTranscriber.App.Views.Dialogs.SpeakerRenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Name this speaker"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="Height" Width="380" ResizeMode="NoResize" ShowInTaskbar="False">

    <Border Background="{StaticResource Brush.Bg.Chrome}" BorderBrush="{StaticResource Brush.Stroke.Hi}"
            BorderThickness="1" CornerRadius="14" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="6" Opacity="0.5" />
        </Border.Effect>
        <StackPanel Margin="20,18,20,16">
            <TextBlock x:Name="PromptText" FontSize="13" FontWeight="SemiBold"
                       Foreground="{StaticResource Brush.Text.Title}" Margin="0,0,0,12" />

            <!-- Quick-pick chips: previously used names (hidden when empty) -->
            <StackPanel x:Name="SuggestionsPanel" Visibility="Collapsed" Margin="0,0,0,10">
                <TextBlock Text="Previously named:" FontSize="10.5"
                           Foreground="{StaticResource Brush.Text.Hint}" Margin="0,0,0,5" />
                <WrapPanel x:Name="ChipsPanel" />
            </StackPanel>

            <TextBox x:Name="NameBox" Style="{StaticResource TextInputStyle}"
                     FontSize="12" Padding="10,7"
                     KeyDown="NameBox_KeyDown" />
            <TextBlock Text="This name is saved to speaker memory and applied to future sessions."
                       FontSize="10.5" Foreground="{StaticResource Brush.Text.Hint}"
                       TextWrapping="Wrap" Margin="0,8,0,0" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Cancel" Style="{StaticResource SubtleButtonStyle}"
                        Padding="16,7" IsCancel="True" />
                <Button Content="Save" Style="{StaticResource PrimaryButtonStyle}"
                        Padding="16,7" Margin="8,0,0,0" IsDefault="True"
                        Click="Save_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
